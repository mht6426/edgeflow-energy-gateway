{
  "device_id": "gw-001",
  "simulate": true,
  "serial_device": "/dev/ttyUSB0",
  "poll_interval_ms": 500,
  "queue_size": 4096,
  "deadband": 0.1,
  "temp_high": 60.0,
  "peak_shaving_threshold_kw": 120.0,
  "max_discharge_kw": 50.0,
  "min_discharge_soc": 30.0,
  "broker_host": "127.0.0.1",
  "broker_port": 1883,
  "mqtt_topic": "plant/line1/gw-001/telemetry",
  "mqtt_alarm_topic": "plant/line1/gw-001/alarm",
  "mqtt_heartbeat_topic": "plant/line1/gw-001/heartbeat",
  "log_dir": "/tmp/edgeflow",
  "metrics_path": "/tmp/edgeflow/metrics.prom",
  "cache_path": "/tmp/edgeflow/offline-cache.jsonl",
  "use_sqlite": true,
  "sqlite_path": "/tmp/edgeflow/edgeflow.db",
  "mqtt_replay_batch": 50,
  "mqtt_keepalive_sec": 60,
  "watchdog_interval_ms": 2000,
  "heartbeat_interval_ms": 5000,
  "modbus_transport": "rtu",
  "modbus_tcp_host": "127.0.0.1",
  "modbus_tcp_port": 502,
  "modbus_slave_id": 1,
  "modbus_baud_rate": 9600,
  "modbus_parity": "N",
  "modbus_data_bits": 8,
  "modbus_stop_bits": 1,
  "modbus_timeout_ms": 500
}
