{
  "device_id": "gw-prod-001",
  "simulate": false,
  "serial_device": "/dev/ttyUSB0",
  "poll_interval_ms": 200,
  "queue_size": 8192,
  "deadband": 0.05,
  "temp_high": 55.0,
  "peak_shaving_threshold_kw": 200.0,
  "max_discharge_kw": 80.0,
  "min_discharge_soc": 25.0,
  "broker_host": "mqtt.plant.local",
  "broker_port": 1883,
  "mqtt_topic": "plant/site-a/gw-prod-001/telemetry",
  "mqtt_alarm_topic": "plant/site-a/gw-prod-001/alarm",
  "mqtt_heartbeat_topic": "plant/site-a/gw-prod-001/heartbeat",
  "log_dir": "/var/log/edgeflow",
  "metrics_path": "/var/lib/edgeflow/metrics.prom",
  "cache_path": "/var/lib/edgeflow/offline-cache.jsonl",
  "use_sqlite": true,
  "sqlite_path": "/var/lib/edgeflow/edgeflow.db",
  "mqtt_replay_batch": 100,
  "mqtt_keepalive_sec": 30,
  "watchdog_interval_ms": 2000,
  "heartbeat_interval_ms": 3000
}
